generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  passwordHash     String
  name             String?
  locale           String            @default("en")
  isAdmin          Boolean           @default(false)
  birthYear        Int?
  country          String?
  avatarUrl        String?
  occupation       String?
  learningGoals    String?           @db.Text   // JSON array of slugs
  dailyTimeGoalMin Int?
  nativeLanguages  String?           @db.Text   // JSON array of ISO-639-1 codes
  createdAt        DateTime          @default(now())
  progress         LessonProgress[]
  attempts         ExerciseAttempt[]
  vocab            VocabItem[]
  activity         UserActivity[]
  ratings          LessonRating[]
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  minuteTs  DateTime // start-of-minute (UTC)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, minuteTs])
  @@index([minuteTs])
}

model Lesson {
  id          String   @id @default(cuid())
  slug        String
  category    String
  title       String
  level       String   // CEFR A1..C2
  description String?  @db.Text
  transcript  String   @db.Text
  segments    Json     // [{ text, hint? }]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ratings     LessonRating[]

  @@unique([category, slug])
  @@index([category, level])
}

model LessonRating {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  stars     Int      // 1..5 (validated in API)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model Exercise {
  id          String   @id @default(cuid())
  slug        String
  skill       String
  title       String
  level       String
  type        String   // mcq | fill | match
  description String?  @db.Text
  questions   Json     // ExerciseQuestion[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([skill, slug])
  @@index([skill, level])
}

model LessonProgress {
  id                String   @id @default(cuid())
  userId            String
  lessonSlug        String
  category          String
  title             String
  segmentsCompleted Int      @default(0)
  totalSegments     Int
  accuracy          Float    @default(0)
  lastOpenedAt      DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonSlug])
  @@index([userId])
}

model ExerciseAttempt {
  id           String   @id @default(cuid())
  userId       String
  exerciseSlug String
  skill        String
  title        String
  score        Float
  completedAt  DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
}

model VocabItem {
  id               String   @id @default(cuid())
  userId           String
  word             String
  definition       String?
  sourceLessonSlug String?
  addedAt          DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId])
}
